        <defaultConnector>
            <targetReference>SetTimesheetEntryIdVariables</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>IsEqualToPrevTimeSheetEntryId</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateOverTimeSheetEntryItems.TimeSheetEntryId</leftValueReference>
