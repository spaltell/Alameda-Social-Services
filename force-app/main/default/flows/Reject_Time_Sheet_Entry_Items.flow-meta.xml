    <decisions>
        <description>Determines whether the time sheet ID of the current record in the loop is the same as the previous one in the loop by checking if PreviousTimesheetId matches the timesheet ID of the current record on the loop.</description>
        <name>IsTimeSheetIdEqualToPreviousTimeSheetId</name>
        <label>Is Time Sheet ID Equal to Previous Time Sheet ID?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>SetTimesheetIdVariables</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>IsEqualToPreviousTimeSheetId</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateOverTimeSheetEntryItems.TimeSheetEntry.TimeSheetId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>PreviousTimesheetId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>IterateOverTimeSheetEntryItems</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether the time sheet entry ID of the current record in the loop is the same as the previous one in the loop by checking if PreviousTimesheeEntrytId matches the timesheet ID of the current record in the loop.</description>
