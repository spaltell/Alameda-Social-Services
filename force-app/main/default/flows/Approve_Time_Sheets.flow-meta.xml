            <operator>Add</operator>
            <value>
                <elementReference>IterateOverTimeSheetEntries.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IterateOverTimeSheetEntries</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets the ApprovedRecordCount to the number of records in the Time Sheets from Get Time Sheets record collection variable.</description>
        <name>SetApprovedRecordCount</name>
        <label>Set Approved Record Count</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>ApprovedRecordCount</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>GetTimeSheets</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>UpdateTimeSheetEntries</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets the RecordIdCount to the number of records in the ids collection variable.</description>
