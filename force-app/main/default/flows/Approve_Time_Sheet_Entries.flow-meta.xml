<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Adds the recordId value to the ids collection.</description>
        <name>AddRecordIdToCollection</name>
        <label>Add Record ID To Collection</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>ids</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>SetRecordIdCount</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Removes the IDs in the UnnaprovedTimeSheetIds variable from the TimeSheetIds variable.</description>
        <name>RemoveUnapprovedTmshtIdsFromVariable</name>
        <label>Remove Unapproved Time Sheet IDs from Variable</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>TimeSheetIds</assignToReference>
            <operator>RemoveAll</operator>
            <value>
                <elementReference>UnapprovedTimeSheetIds</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>UpdateTimeSheets</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets the ApprovedRecordCount to the number of records in the Time Sheet Entries from Get Time Sheet Entries collection variable.</description>
        <name>SetApprovedRecordCount</name>
        <label>Set Approved Record Count</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>ApprovedRecordCount</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>GetTimeSheetEntries</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>UpdateTimeSheetEntryItems</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets the RecordIdCount to the number of records in the ids collection variable.</description>
        <name>SetRecordIdCount</name>
        <label>Set Record ID Count</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>RecordIdCount</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>ids</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>RecordCountLessThanOrEqualToMaximum</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Adds the time sheet ID of the current record in the loop to the TimeSheetIds collection variable and the PreviousTimesheetId variable.</description>
        <name>SetTimesheetIdVariables</name>
        <label>Set Timesheet ID Variables</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>TimeSheetIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>IterateOverTimeSheetEntries.TimeSheetId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>PreviousTimeSheetId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>IterateOverTimeSheetEntries.TimeSheetId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IterateOverTimeSheetEntries</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Adds the time sheet ID of the current record in the loop to the UnapprovedTimeSheetIds collection variable and the PreviousUnapprovedTimeSheetId variable.</description>
        <name>SetUnapprovedTimesheetIdVariables</name>
        <label>Set Unapproved Timesheet ID Variables</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>UnapprovedTimeSheetIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>IterateOverUnapprovedTimeSheetEntries.TimeSheetId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>PreviousUnapprovedTimeSheetId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>IterateOverUnapprovedTimeSheetEntries.TimeSheetId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IterateOverUnapprovedTimeSheetEntries</targetReference>
        </connector>
    </assignments>
    <constants>
        <description>Stores the maximum number of time sheet entry record IDs that can be approved.</description>
        <name>MaximumRecordIdCount</name>
        <dataType>Number</dataType>
        <value>
            <numberValue>50.0</numberValue>
        </value>
    </constants>
    <constants>
        <description>Stores the text that is displayed to the flow user when no records are found.</description>
        <name>NoRecordFoundText</name>
        <dataType>String</dataType>
        <value>
            <stringValue>We couldn’t find time sheet entry records. Ask your admin for help.</stringValue>
        </value>
    </constants>
    <constants>
        <description>Stores the text that’s shown when time sheet entry records are approved.</description>
        <name>TimeSheetEntriesApprovedMessage</name>
        <dataType>String</dataType>
        <value>
            <stringValue>The time sheet entries were approved.</stringValue>
        </value>
    </constants>
    <constants>
        <description>Stores the text that’s shown when a time sheet entry record is approved.</description>
        <name>TimeSheetEntryApprovedMessage</name>
        <dataType>String</dataType>
        <value>
            <stringValue>The time sheet entry was approved.</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Determines whether a Record ID was passed into the flow by checking if the recordId variable contains a value.</description>
        <name>HaveRecordId</name>
        <label>Have Record ID?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>SetRecordIdCount</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>HasRecordId</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AddRecordIdToCollection</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether a Record ID was passed into the flow.</description>
        <name>HaveRecordIdDisplayApproval</name>
        <label>Have Record ID?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>ScrnTimeSheetEntriesApprovedMessage</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No  (Default)</defaultConnectorLabel>
        <rules>
            <name>HasRecordIdDisplayApproval</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ScrnTimeSheetEntryApprovedMessage</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether time sheet entry records were found by checking if the Time Sheet Entries from Get Time Sheet Entries record collection contains a record.</description>
        <name>HaveTimeSheetEntries</name>
        <label>Have Time Sheet Entries?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>ScreenDisplayErrorNoRecords</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>HasTimeSheetEntries</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetTimeSheetEntries</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetTimeSheetEntries</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateTimeSheetEntries</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether the time sheet ID of the current record in the loop is the same as the previous one in the loop by checking if PreviousTimesheetId matches the timesheet ID of the current record in the loop.</description>
        <name>IsTimeSheetIdEqualToPreviousTimeSheetId</name>
        <label>Is Time Sheet ID Equal To Previous Time Sheet ID?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>SetTimesheetIdVariables</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>IsEqualToPrevTimeSheetId</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateOverTimeSheetEntries.TimeSheetId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>PreviousTimeSheetId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>IterateOverTimeSheetEntries</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether the time sheet ID of the current record in the loop is the same as the previous one in the loop by checking if PreviousTimesheetId matches the timesheet ID of the current record in the loop.</description>
        <name>IsTmshtEqualToPreviousTmshtIdUnnaproved</name>
        <label>Is Time Sheet ID Equal To Previous Time Sheet ID?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>SetUnapprovedTimesheetIdVariables</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>IsEqualToPrevUnnaprovedTimeSheetId</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateOverUnapprovedTimeSheetEntries.TimeSheetId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>PreviousUnapprovedTimeSheetId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>IterateOverUnapprovedTimeSheetEntries</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether the record count exceeds the allowed maximum by checking whether RecordIdCount is less than or equal to MaximumRecordIdCount.</description>
        <name>RecordCountLessThanOrEqualToMaximum</name>
        <label>Record Count Less Than or Equal to Maximum?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>ScreenDisplayErrorMaxRecords</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>DoesHaveRecCountLessThanOrEqualToMaximum</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RecordIdCount</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>MaximumRecordIdCount</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetTimeSheetEntries</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>DS</description>
    <environments>Default</environments>
    <interviewLabel>Approve Time Sheet Entries {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Approve Time Sheet Entries</label>
    <loops>
        <description>Repeats actions for each record in the Time Sheet Entries from Get Time Sheet Entries collection.</description>
        <name>IterateOverTimeSheetEntries</name>
        <label>Iterate Over Time Sheet Entries</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>GetTimeSheetEntries</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>IsTimeSheetIdEqualToPreviousTimeSheetId</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>GetUnapprovedTimeSheetEntries</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <description>Repeats actions for each record in the Time Sheet Entries from Get Unapproved Time Sheet Entries collection.</description>
        <name>IterateOverUnapprovedTimeSheetEntries</name>
        <label>Iterate Over Unapproved Time Sheet Entries</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>GetUnapprovedTimeSheetEntries</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>IsTmshtEqualToPreviousTmshtIdUnnaproved</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>RemoveUnapprovedTmshtIdsFromVariable</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
