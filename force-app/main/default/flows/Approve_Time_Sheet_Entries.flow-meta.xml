        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>SetApprovedRecordCount</targetReference>
        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>RollbackRecordChanges</targetReference>
