        </filters>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>StatusComment</field>
            <value>
                <stringValue></stringValue>
            </value>
        </inputAssignments>
        <object>TimeSheetEntryItem</object>
